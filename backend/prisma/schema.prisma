// ===========================================
// TASKY - Schéma Prisma complet v6
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
  url       = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  role          Role     @default(CLIENT)
  firstName     String
  lastName      String
  phone         String   @unique
  city          String?
  avatar        String?
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client?
  prestataire   Prestataire?
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  emailLogs          EmailLog[]

  @@map("users")
}

enum Role {
  CLIENT
  PRESTATAIRE
  ADMIN
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Client {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  demandes Demande[]
  reviews  Review[]

  @@map("clients")
}

model Prestataire {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  rating        Float         @default(0)
  reviewCount   Int           @default(0)
  disponibilite Disponibilite @default(ACTIF)
  pointDepotAdresse      String?
  pointDepotVille        String?
  pointDepotCodePostal   String?
  pointDepotLat          Float?
  pointDepotLng          Float?
  pointDepotInstructions String?
  tauxReussite  Float @default(0)
  delaiMoyen    Int   @default(0)
  tempsReponse  Int   @default(0)
  iban         String?
  bic          String?
  bankName     String?
  ibanVerified Boolean @default(false)
  competences  Competence[]
  devis        Devis[]
  prestations  Prestation[]
  reviews      Review[]
  portfolio    PortfolioImage[]

  @@map("prestataires")
}

enum Disponibilite {
  ACTIF
  OCCUPE
  ABSENT
}

model Category {
  id            String        @id
  nom           String
  slug          String        @unique
  icon          String
  description   String?
  subCategories SubCategory[]
  competences   Competence[]
  demandes      Demande[]

  @@map("categories")
}

model SubCategory {
  id            String         @id
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  nom           String
  slug          String
  interventions Intervention[]
  prestations   Prestation[]
  demandes      Demande[]
  competences   Competence[]

  @@map("sub_categories")
}

model Intervention {
  id            String      @id
  nom           String
  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  competences   Competence[]

  @@map("interventions")
}

model Demande {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id])
  titre           String
  description     String
  typePrestation  TypePrestation
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  subCategoryId   String?
  subCategory     SubCategory?   @relation(fields: [subCategoryId], references: [id])
  interventionIds String[]
  budget          Float?
  ville           String?
  photos          String[]
  dateEcheance    DateTime?
  urgence         UrgenceDemande @default(NORMAL)
  status          StatusDemande  @default(PUBLIEE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  devis           Devis[]
  prestation      Prestation?
  signalements    Signalement[]

  @@map("demandes")
}

enum TypePrestation {
  MODIFICATION
  CREATION
  FORMATION
}

enum UrgenceDemande {
  NORMAL
  URGENT
  TRES_URGENT
}

enum StatusDemande {
  PUBLIEE
  EN_ATTENTE_INSPECTION
  EN_ATTENTE_PAIEMENT
  EN_COURS
  A_VALIDER
  TERMINEE
  SUPPRIMEE
  ANNULEE
}

model Devis {
  id               String      @id @default(cuid())
  demandeId        String
  demande          Demande     @relation(fields: [demandeId], references: [id])
  prestataireId    String
  prestataire      Prestataire @relation(fields: [prestataireId], references: [id])
  montant          Float
  delai            Int
  description      String
  status           StatusDevis @default(ENVOYE)
  estSelectionnable Boolean    @default(true)
  aVerifier        Boolean     @default(false)
  expiresAt        DateTime
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("devis")
}

enum StatusDevis {
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

model Prestation {
  id             String           @id @default(cuid())
  demandeId      String           @unique
  demande        Demande          @relation(fields: [demandeId], references: [id])
  prestataireId  String
  prestataire    Prestataire      @relation(fields: [prestataireId], references: [id])
  subCategoryId  String?
  subCategory    SubCategory?     @relation(fields: [subCategoryId], references: [id])
  montant        Float
  montantFinal   Float?
  status         StatusPrestation @default(EN_ATTENTE_INSPECTION)
  createdAt      DateTime         @default(now())
  completedAt    DateTime?
  validatedAt    DateTime?
  autoValidateAt DateTime?
  review         Review?
  etatDesLieux   EtatDesLieux?
  messages       Message[]

  @@map("prestations")
}

enum StatusPrestation {
  EN_ATTENTE_INSPECTION
  EN_ATTENTE_PAIEMENT
  EN_COURS
  A_VALIDER
  TERMINEE
  ANNULEE
}

model EtatDesLieux {
  id            String            @id @default(cuid())
  prestationId  String            @unique
  prestation    Prestation        @relation(fields: [prestationId], references: [id])
  description   String
  photos        String[]
  montantRevise Float?
  status        StatusEtatDesLieux @default(EN_ATTENTE)
  createdAt     DateTime          @default(now())

  @@map("etats_des_lieux")
}

enum StatusEtatDesLieux {
  EN_ATTENTE
  VALIDE
  REFUSE
}

model Message {
  id           String     @id @default(cuid())
  prestationId String
  prestation   Prestation @relation(fields: [prestationId], references: [id])
  auteurId     String
  contenu      String
  lu           Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@map("messages")
}

model Signalement {
  id        String   @id @default(cuid())
  demandeId String
  demande   Demande  @relation(fields: [demandeId], references: [id])
  auteurId  String
  message   String
  statut    String   @default("EN_ATTENTE")
  createdAt DateTime @default(now())

  @@map("signalements")
}

model Review {
  id            String      @id @default(cuid())
  prestationId  String      @unique
  prestation    Prestation  @relation(fields: [prestationId], references: [id])
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())

  @@map("reviews")
}

model PortfolioImage {
  id            String      @id @default(cuid())
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  url           String
  caption       String?
  createdAt     DateTime    @default(now())

  @@map("portfolio_images")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  type      String
  status    String
  resendId  String?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("email_logs")
}

model Competence {
  id             String        @id @default(cuid())
  prestataireId  String
  prestataire    Prestataire   @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  subCategoryId  String?
  subCategory    SubCategory?  @relation(fields: [subCategoryId], references: [id])
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id])

  @@map("competences")
}
