# ============================================
# TASKY BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

PORT=3001
NODE_ENV=production

# Base de données Supabase (staging)
# Récupérer depuis : Supabase > Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres"

# JWT — Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERER_UN_SECRET_64_CHARS"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="GENERER_UN_AUTRE_SECRET_64_CHARS"
JWT_REFRESH_EXPIRES_IN="30d"

# Frontend URL (CORS)
FRONTEND_URL="https://tasky-staging.vercel.app"

# Bcrypt
BCRYPT_ROUNDS=12

# Email (Resend)
RESEND_API_KEY="re_VOTRE_CLE_RESEND"
EMAIL_FROM="noreply@tasky.fr"

# Stripe (clés de TEST pour staging)
STRIPE_SECRET_KEY="sk_test_VOTRE_CLE_SECRETE"
STRIPE_WEBHOOK_SECRET="whsec_VOTRE_SECRET_WEBHOOK"

# Supabase (pour les avatars)
SUPABASE_URL="https://XXXX.supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_XXXX"

# Redis (Upstash)
REDIS_URL="redis://default:PASSWORD@XXXX.upstash.io:6379"
