// Ajoutez ceci à votre fichier schema.prisma

/**
 * Catégorie principale de prestations
 */
model Categorie {
  id              String          @id @default(uuid())
  nom             String
  icon            String
  description     String
  ordre           Int             @default(0) // Pour définir l'ordre d'affichage
  sousCategories  SousCategorie[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("categories")
}

/**
 * Sous-catégorie de prestations
 */
model SousCategorie {
  id           String        @id @default(uuid())
  nom          String
  ordre        Int           @default(0) // Pour définir l'ordre d'affichage
  categorieId  String
  categorie    Categorie     @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  prestations  Prestation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("sous_categories")
}

/**
 * Prestation individuelle
 */
model Prestation {
  id              String         @id @default(uuid())
  nom             String
  ordre           Int            @default(0) // Pour définir l'ordre d'affichage
  sousCategorieId String
  sousCategorie   SousCategorie  @relation(fields: [sousCategorieId], references: [id], onDelete: Cascade)
  
  // Relation avec les demandes clients
  demandes        Demande[]
  
  // Relation avec les prestataires qui proposent cette prestation
  prestatairesPrestations PrestatairePrestation[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("prestations")
}

/**
 * Table de jonction : Prestataires et leurs prestations proposées
 */
model PrestatairePrestation {
  id            String      @id @default(uuid())
  prestataire   User        @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  prestataireId String
  prestation    Prestation  @relation(fields: [prestationId], references: [id], onDelete: Cascade)
  prestationId  String
  
  // Prix de base proposé par le prestataire pour cette prestation
  prixBase      Float?
  
  // Temps estimé en minutes
  dureeEstimee  Int?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([prestataireId, prestationId])
  @@map("prestataire_prestations")
}

/**
 * Demande de prestation d'un client
 */
model Demande {
  id              String      @id @default(uuid())
  titre           String
  description     String      @db.Text
  budgetEstime    Float?
  
  // Relation avec la prestation
  prestationId    String
  prestation      Prestation  @relation(fields: [prestationId], references: [id])
  
  // Client qui fait la demande
  clientId        String
  client          User        @relation("ClientDemandes", fields: [clientId], references: [id], onDelete: Cascade)
  
  // Statut de la demande
  statut          StatutDemande @default(PUBLIEE)
  
  // Localisation
  codePostal      String?
  ville           String?
  
  // Photos
  photos          String[]    // Array d'URLs
  
  // Date souhaitée
  dateSouhaitee   DateTime?
  
  // Devis reçus
  devis           Devis[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("demandes")
}

/**
 * Statut d'une demande
 */
enum StatutDemande {
  PUBLIEE       // Demande publiée, en attente de devis
  EN_ATTENTE    // En attente de choix du client
  ACCEPTEE      // Devis accepté par le client
  EN_COURS      // Prestation en cours
  TERMINEE      // Prestation terminée
  ANNULEE       // Demande annulée
}

/**
 * Devis envoyé par un prestataire
 */
model Devis {
  id              String        @id @default(uuid())
  
  // Relation avec la demande
  demandeId       String
  demande         Demande       @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  
  // Prestataire qui envoie le devis
  prestataireId   String
  prestataire     User          @relation("PrestataireDevis", fields: [prestataireId], references: [id], onDelete: Cascade)
  
  // Contenu du devis
  prixPropose     Float
  delaiEstime     Int           // En jours
  message         String        @db.Text
  
  // Statut du devis
  statut          StatutDevis   @default(ENVOYE)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("devis")
}

/**
 * Statut d'un devis
 */
enum StatutDevis {
  ENVOYE        // Devis envoyé au client
  ACCEPTE       // Devis accepté par le client
  REFUSE        // Devis refusé par le client
  ANNULE        // Devis annulé par le prestataire
}

// Ajoutez ces relations au modèle User existant
model User {
  // ... vos champs existants ...
  
  // Relations pour les catégories
  prestationsProposes PrestatairePrestation[]
  
  // Demandes créées (si client)
  demandes            Demande[]            @relation("ClientDemandes")
  
  // Devis envoyés (si prestataire)
  devisEnvoyes        Devis[]              @relation("PrestataireDevis")
}
